---
interface Props {
  /** Breadcrumb segments: group names followed by page title (last item). */
  trail: string[];
}

const { trail } = Astro.props;
---

<nav class="breadcrumb" aria-label="Breadcrumb">
  {trail.map((item, i) => (
    <>
      {i > 0 && <span class="breadcrumb-sep">/</span>}
      <span class:list={['breadcrumb-item', { current: i === trail.length - 1 }]}>{item}</span>
    </>
  ))}
</nav>
