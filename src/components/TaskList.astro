---
import type { NavTree } from '../utils/navigation';
import type { Task } from '../utils/tasks';
import TaskCard from './TaskCard.astro';

interface Props {
  tasks: Task[];
  navTree?: NavTree;
}

const { tasks, navTree } = Astro.props;
---

<div class="task-list">
  {tasks.length === 0 ? (
    <p class="task-list-empty">No tasks defined.</p>
  ) : (
    <ul class="task-list-grid">
      {tasks.map((task) => (
        <li>
          <TaskCard task={task} navTree={navTree} />
        </li>
      ))}
    </ul>
  )}
</div>
