---
import type { NavTab } from '../utils/navigation';
import { withBase } from '../utils/base';

interface Props {
  tabs: NavTab[];
  activeTab: string;
  base?: string;
}

const { tabs, activeTab, base = '/' } = Astro.props;
---

<nav class="tab-bar">
  <div class="tab-bar-inner">
    {tabs.map((tab) => {
      const firstPage = tab.groups[0]?.pages[0];
      const href = firstPage ? withBase(firstPage.href, base) : '#';
      const isActive = tab.slug === activeTab;
      return (
        <a href={href} class:list={['tab-item', { active: isActive }]}>
          {tab.name}
        </a>
      );
    })}
  </div>
</nav>
