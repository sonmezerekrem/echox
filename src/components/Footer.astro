---
import type { FooterConfig } from '../utils/config';
import { withBase } from '../utils/base';

interface Props {
  footer?: FooterConfig;
  siteName: string;
  base?: string;
}

const { footer, siteName, base = '/' } = Astro.props;

if (!footer) return;

const { message, columns = [] } = footer;
---

<footer class="site-footer">
  <div class="container">
    {columns.length > 0 && (
      <div class="footer-columns" style={`--footer-col-count: ${columns.length}`}>
        {columns.map((col) => (
          <div class="footer-column">
            <h4 class="footer-column-title">{col.title}</h4>
            <ul class="footer-column-links">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.external ? link.url : withBase(link.url, base)}
                    class="footer-link"
                    target={link.external ? '_blank' : undefined}
                    rel={link.external ? 'noopener noreferrer' : undefined}
                  >
                    {link.label}
                    {link.external && (
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 7L6 18" /><path d="M11 7h6v6" />
                      </svg>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    )}
    {message && (
      <div class="footer-message">{message}</div>
    )}
  </div>
</footer>
