---
import type { ApiEndpoint } from '../utils/openapi';

interface Props {
  endpoint: ApiEndpoint;
}

const { endpoint } = Astro.props;

const methodClass = `method-${endpoint.method.toLowerCase()}`;

const paramsByLocation = {
  path: endpoint.parameters.filter((p) => p.in === 'path'),
  query: endpoint.parameters.filter((p) => p.in === 'query'),
  header: endpoint.parameters.filter((p) => p.in === 'header'),
};
---

<div class="endpoint">
  <div class="endpoint-header">
    <span class={`method-badge ${methodClass}`}>{endpoint.method}</span>
    <code class="endpoint-path">{endpoint.path}</code>
  </div>

  {endpoint.description && (
    <p class="endpoint-description">{endpoint.description}</p>
  )}

  {paramsByLocation.path.length > 0 && (
    <div class="endpoint-section">
      <h3>Path Parameters</h3>
      <table class="param-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Required</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          {paramsByLocation.path.map((p) => (
            <tr>
              <td><code>{p.name}</code></td>
              <td><code>{p.type}</code></td>
              <td>{p.required ? 'Yes' : 'No'}</td>
              <td>{p.description}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  {paramsByLocation.query.length > 0 && (
    <div class="endpoint-section">
      <h3>Query Parameters</h3>
      <table class="param-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Required</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          {paramsByLocation.query.map((p) => (
            <tr>
              <td><code>{p.name}</code></td>
              <td><code>{p.type}</code></td>
              <td>{p.required ? 'Yes' : 'No'}</td>
              <td>{p.description}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  {paramsByLocation.header.length > 0 && (
    <div class="endpoint-section">
      <h3>Header Parameters</h3>
      <table class="param-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Required</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          {paramsByLocation.header.map((p) => (
            <tr>
              <td><code>{p.name}</code></td>
              <td><code>{p.type}</code></td>
              <td>{p.required ? 'Yes' : 'No'}</td>
              <td>{p.description}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  {endpoint.requestBody && (
    <div class="endpoint-section">
      <h3>Request Body</h3>
      {endpoint.requestBody.description && (
        <p>{endpoint.requestBody.description}</p>
      )}
      <div class="content-type-badge">{endpoint.requestBody.contentType}</div>
      {endpoint.requestBody.example && endpoint.requestBody.example !== 'undefined' && (
        <pre class="api-code-block"><code>{endpoint.requestBody.example}</code></pre>
      )}
    </div>
  )}

  {endpoint.responses.length > 0 && (
    <div class="endpoint-section">
      <h3>Responses</h3>
      {endpoint.responses.map((resp) => (
        <div class="response-entry">
          <div class="response-header">
            <span class={`response-code ${parseInt(resp.code) < 300 ? 'response-success' : parseInt(resp.code) < 400 ? 'response-redirect' : 'response-error'}`}>
              {resp.code}
            </span>
            <span class="response-desc">{resp.description}</span>
          </div>
          {resp.example && resp.example !== 'undefined' && (
            <pre class="api-code-block"><code>{resp.example}</code></pre>
          )}
        </div>
      ))}
    </div>
  )}
</div>
