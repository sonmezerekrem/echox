---
import type { NavTree } from '../utils/navigation';
import type { Task } from '../utils/tasks';
import { getPageNameByPath } from '../utils/navigation';

interface Props {
  task: Task;
  navTree?: NavTree;
}

const { task, navTree } = Astro.props;
const relationItems = (task.relations ?? []).map((r) => {
  const item = typeof r === 'string' ? { label: r, url: r.startsWith('http') ? r : `/${r}` } : r;
  const isInternal = item.url.startsWith('/') && !item.url.startsWith('//') && !item.url.startsWith('http');
  const displayLabel = navTree && isInternal && !item.url.startsWith('/#')
    ? getPageNameByPath(navTree, item.url.replace(/^#/, ''))
    : null;
  return { ...item, displayLabel };
});
const statusSlug = task.status.toLowerCase().replace(/\s+/g, '-');

const typeLabel =
  task.type &&
  task.type
    .split(/[_\s-]+/)
    .map((p) => p.charAt(0).toUpperCase() + p.slice(1))
    .join(' ');

const createdShort = task.createdAt ? task.createdAt.slice(0, 10) : null;
const updatedShort = task.updatedAt ? task.updatedAt.slice(0, 10) : null;
---

<article class="task-card" id={`task-${task.id}`}>
  <div class="task-card-header">
    <span class="task-id">{task.id}</span>
    <span class={`status-badge status-badge-sm status-${statusSlug}`}>{task.status}</span>
  </div>
  <h3 class="task-name">{task.name}</h3>
  {(typeLabel || createdShort || updatedShort) && (
    <div class="task-meta">
      {typeLabel && <span class="task-type-pill">{typeLabel}</span>}
      {(createdShort || updatedShort) && (
        <span class="task-dates">
          {createdShort && <span>Created {createdShort}</span>}
          {updatedShort && (
            <>
              {createdShort && <span class="task-date-separator">•</span>}
              <span>Updated {updatedShort}</span>
            </>
          )}
        </span>
      )}
    </div>
  )}
  {task.description && (
    <p class="task-description">{task.description}</p>
  )}
  {task.labels && task.labels.length > 0 && (
    <div class="task-labels">
      {task.labels.map((label) => (
        <span class="task-label">{label}</span>
      ))}
    </div>
  )}
  {task.steps && task.steps.length > 0 && (
    <div class="task-section">
      <div class="task-section-title">Steps</div>
      <ol class="task-steps">
        {task.steps.map((step) => (
          <li>{step}</li>
        ))}
      </ol>
    </div>
  )}
  {task.acceptanceCriteria && task.acceptanceCriteria.length > 0 && (
    <div class="task-section">
      <div class="task-section-title">Acceptance criteria</div>
      <ul class="task-acceptance">
        {task.acceptanceCriteria.map((crit) => (
          <li>{crit}</li>
        ))}
      </ul>
    </div>
  )}
  {task.dependencies && task.dependencies.length > 0 && (
    <div class="task-section task-dependencies">
      <div class="task-section-title">Depends on</div>
      <div class="task-dependencies-list">
        {task.dependencies.map((dep) => (
          <a href={`#task-${dep}`} class="task-dependency-pill">
            {dep}
          </a>
        ))}
      </div>
    </div>
  )}
  {relationItems.length > 0 && (
    <div class="task-relations">
      <span class="task-relations-title">Related:</span>
      <ul class="task-relations-list">
        {relationItems.map((r) => (
          <li>
            <a
              href={r.url}
              class="task-relation-link"
              target={r.url.startsWith('http') ? '_blank' : undefined}
              rel={r.url.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              {r.displayLabel ?? r.label ?? r.url}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}
</article>
