---
import type { NavGroup } from '../utils/navigation';
import SidebarGroup from './SidebarGroup.astro';

interface Props {
  groups: NavGroup[];
  currentSlug: string;
  base?: string;
}

const { groups, currentSlug, base = '/' } = Astro.props;
---

<aside class="sidebar">
  <nav class="sidebar-nav">
    {groups.map((group) => (
      <SidebarGroup group={group} currentSlug={currentSlug} base={base} />
    ))}
  </nav>
</aside>
