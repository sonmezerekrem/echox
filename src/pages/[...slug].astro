---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';
import { buildFullNavTree, findCurrentTab } from '../utils/navigation';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  const navTree = buildFullNavTree(entries);

  return entries.map((entry) => {
    const currentTab = findCurrentTab(navTree, entry.id);
    return {
      params: { slug: entry.id },
      props: { entry, navTree, activeTab: currentTab?.slug ?? '' },
    };
  });
}

const { entry, navTree, activeTab } = Astro.props;
const { Content, headings } = await render(entry);
const data = entry.data as { name?: string; status?: string };
const title = data.name
  ?? entry.id.split('/').pop()?.replace(/[-_]/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
  ?? 'Untitled';
const status = data.status;
---

<DocsLayout
  title={title}
  navTree={navTree}
  activeTab={activeTab}
  currentSlug={entry.id}
  headings={headings}
  status={status}
>
  <Content />
</DocsLayout>
