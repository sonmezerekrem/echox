---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';
import TaskList from '../components/TaskList.astro';
import { buildFullNavTree, findCurrentTab } from '../utils/navigation';
import { getTabsWithTasks, loadTasksForTab } from '../utils/tasks';
import { getFirstH1AsNameAndAttrs } from '../utils/page-name';

function toStatusSlug(val: string): string {
  return val.toLowerCase().replace(/\s+/g, '-');
}

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  const augmentedEntries = entries.map((entry) => {
    const data = entry.data as { name?: string; title?: string; status?: string };
    if (data.name ?? data.title) return entry;
    const h1 = getFirstH1AsNameAndAttrs(entry.id);
    if (!h1) return entry;
    const updates: Record<string, string> = { name: h1.name };
    const statusFromAttrs = h1.attributes?.status ?? h1.attributes?.label;
    if (statusFromAttrs) updates.status = toStatusSlug(statusFromAttrs);
    return { ...entry, data: { ...entry.data, ...updates } };
  });
  const navTree = buildFullNavTree(augmentedEntries);

  const paths = augmentedEntries.map((entry) => {
    const currentTab = findCurrentTab(navTree, entry.id);
    return {
      params: { slug: entry.id },
      props: { entry, navTree, activeTab: currentTab?.slug ?? '' },
    };
  });

  for (const tab of getTabsWithTasks()) {
    const allTasks = loadTasksForTab(tab);
    const fullNav = buildFullNavTree(entries);

    ([
      { slug: 'todo', title: 'Todo' },
      { slug: 'in-progress', title: 'In progress' },
      { slug: 'done', title: 'Done' },
    ] as const).forEach(({ slug, title }) => {
      paths.push({
        params: { slug: `${tab}/tasks/${slug}` },
        props: {
          tasksPage: true,
          tabSlug: tab,
          navTree: fullNav,
          activeTab: tab,
          tasks: allTasks,
          tasksStatus: slug,
          tasksTitle: title,
          currentSlug: `${tab}/tasks/${slug}`,
        },
      });
    });
  }

  return paths;
}

const props = Astro.props;
const { navTree, activeTab, tasksPage, tasks, currentSlug, tasksStatus, tasksTitle } = props;
const entry = 'entry' in props ? props.entry : null;

let DocContent: Awaited<ReturnType<typeof render>>['Content'] | null = null;
let docTitle = '';
let docStatus: string | undefined;
let docHeadings: Awaited<ReturnType<typeof render>>['headings'] = [];
let tasksHeadings: { depth: number; slug: string; text: string }[] = [];
let filteredTasks = tasks ?? [];
let dependencyStatus: Record<string, string> = {};

if (entry) {
  const rendered = await render(entry);
  DocContent = rendered.Content;
  docHeadings = rendered.headings;
  const data = entry.data as { name?: string; status?: string };
  docTitle = data.name
    ?? entry.id.split('/').pop()?.replace(/[-_]/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
    ?? 'Untitled';
  docStatus = data.status;
}

if (tasksPage && Array.isArray(tasks)) {
  dependencyStatus = tasks.reduce<Record<string, string>>((map, t) => {
    if (t.id && typeof t.status === 'string') {
      map[t.id] = t.status.toLowerCase().replace(/\s+/g, '-');
    }
    return map;
  }, {});

  filteredTasks = tasks.filter(
    (t) =>
      typeof t.status === 'string' &&
      t.status.toLowerCase().replace(/\s+/g, '-') === (tasksStatus ?? '')
  );
  tasksHeadings = filteredTasks.map((t) => ({
    depth: 2,
    slug: `task-${t.id}`,
    text: `${t.id}: ${t.name}`,
  }));
}

---

{tasksPage ? (
  <DocsLayout
    title={tasksTitle ?? 'Tasks'}
    navTree={navTree}
    activeTab={activeTab}
    currentSlug={currentSlug!}
    headings={tasksHeadings}
  >
    <TaskList
      tasks={filteredTasks}
      navTree={navTree}
      tabSlug={props.tabSlug}
      dependencyStatus={dependencyStatus}
    />
  </DocsLayout>
) : DocContent && entry ? (
  <DocsLayout
    title={docTitle}
    navTree={navTree}
    activeTab={activeTab}
    currentSlug={entry.id}
    headings={docHeadings}
    status={docStatus}
  >
    <DocContent />
  </DocsLayout>
) : null}
